static void uart_set_baudrate(uint32_t periph_clk, uint32_t baudrate){
	USART -> BRR = compute_uart_bd(periph_clk, baudrate);
}
static void compute_uart_bd(uint32_t periph_clk, uint32_t baudrate){		//calculate baud rate to initialize UART peripheral
	((periph_clk + (baudrate/2u))/baudrate);
